---
import { getPosts } from "../../lib/mock";
import ItemDetail from "../../components/ItemDetail.svelte";
import Seo from "../../components/Seo.astro";

export async function getStaticPaths() {
  const posts = await getPosts(0);
  return posts.map((post) => ({
    params: { id: String(post.id) },
    props: { post },
  }));
}

const { post } = Astro.props;
const priceText = post.price.toLocaleString("ko-KR") + "원";
const ogDescription = `${priceText} · ${post.location} · ${post.description.replace(/\s+/g, " ")}`
  .trim()
  .slice(0, 150);
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Seo
      title={post.title}
      description={ogDescription}
      image={post.thumbnail}
      type="article"
    />
    <style is:global>
      * {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
        background: #fff;
        -webkit-font-smoothing: antialiased;
      }
      .topbar {
        position: sticky;
        top: 0;
        z-index: 20;
        max-width: 720px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        height: 52px;
        padding: 0 0.5rem;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(8px);
        font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
      }
      .topbar a {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.5rem 0.75rem;
        color: #212124;
        text-decoration: none;
        font-size: 0.9375rem;
      }
    </style>
  </head>
  <body>
    <nav class="topbar">
      <a href="/">← 목록</a>
    </nav>
    <main>
      <ItemDetail post={post} client:load />
    </main>
  </body>
</html>
